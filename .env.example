# ============================================================================
# PRAXO — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values.
# Lines marked [REQUIRED] must be set for the app to start.
# Lines marked [OPTIONAL] have sensible defaults.
# Lines marked [BYOK] require a user-provided API key for that provider.
# ============================================================================

# ----------------------------------------------------------------------------
# DEPLOYMENT MODE
# ----------------------------------------------------------------------------
# "lite" = SQLite, no Docker, no code execution
# "full" = PostgreSQL, Judge0, all features
DEPLOYMENT_MODE=lite                    # [REQUIRED] "lite" or "full"

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
# Lite mode: SQLite (file-based, no setup needed)
# Full mode: PostgreSQL connection string
# The app automatically selects the right Prisma datasource based on DEPLOYMENT_MODE.
DATABASE_URL=file:./praxo.db            # [REQUIRED] Lite default. Full mode example: postgresql://praxo:praxo@localhost:5432/praxo

# ----------------------------------------------------------------------------
# ACCESS PROTECTION
# ----------------------------------------------------------------------------
# Praxo is single-user by design (no login/registration needed).
# If you expose Praxo beyond localhost (e.g., on a LAN), set a PIN to prevent
# unauthorized access. Leave blank if running only on localhost.
PRAXO_ACCESS_PIN=                       # [OPTIONAL] Simple PIN to protect access (e.g., 4-8 digits)

# ----------------------------------------------------------------------------
# LLM PROVIDERS (at least one required)
# ----------------------------------------------------------------------------
# The user selects which provider to use in the UI.
# Only the selected provider's key needs to be valid.

# OpenAI
OPENAI_API_KEY=                         # [BYOK] Required for OpenAI models + OpenAI TTS
OPENAI_BASE_URL=https://api.openai.com/v1  # [OPTIONAL] Override for proxies/compatible APIs
OPENAI_DEFAULT_MODEL=gpt-4o            # [OPTIONAL] Default model when OpenAI is selected

# Anthropic (Claude)
ANTHROPIC_API_KEY=                      # [BYOK] Required for Claude models
ANTHROPIC_BASE_URL=https://api.anthropic.com  # [OPTIONAL] Override for proxies
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514  # [OPTIONAL] Default Claude model

# Google (Gemini)
GEMINI_API_KEY=                         # [BYOK] Required for Gemini models
GEMINI_DEFAULT_MODEL=gemini-2.5-pro    # [OPTIONAL] Default Gemini model

# Groq
GROQ_API_KEY=                           # [BYOK] Required for Groq-hosted models
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile  # [OPTIONAL] Default Groq model

# OpenRouter
OPENROUTER_API_KEY=                     # [BYOK] Required for OpenRouter
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514  # [OPTIONAL] Default OpenRouter model

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434  # [OPTIONAL] Ollama server URL
OLLAMA_DEFAULT_MODEL=llama3.1          # [OPTIONAL] Default Ollama model

# ----------------------------------------------------------------------------
# VOICE — SPEECH-TO-TEXT (STT)
# ----------------------------------------------------------------------------
# Primary: Deepgram (cloud, requires key)
# Fallback: Whisper (local, requires model download)
STT_PROVIDER=deepgram                   # [REQUIRED] "deepgram" or "whisper"

# Deepgram
DEEPGRAM_API_KEY=                       # [BYOK] Required when STT_PROVIDER=deepgram
DEEPGRAM_MODEL=nova-2                   # [OPTIONAL] Deepgram model
DEEPGRAM_LANGUAGE=en-US                 # [OPTIONAL] Language code

# Whisper (local)
WHISPER_MODEL_SIZE=base                 # [OPTIONAL] tiny, base, small, medium, large
WHISPER_DEVICE=cpu                      # [OPTIONAL] cpu or cuda

# ----------------------------------------------------------------------------
# VOICE — TEXT-TO-SPEECH (TTS)
# ----------------------------------------------------------------------------
# OpenAI TTS (cloud, uses OPENAI_API_KEY above)
# Kokoro (local, no key needed)
TTS_PROVIDER=openai                     # [REQUIRED] "openai" or "kokoro"

# OpenAI TTS
OPENAI_TTS_MODEL=tts-1                  # [OPTIONAL] tts-1 or tts-1-hd
OPENAI_TTS_VOICE=alloy                  # [OPTIONAL] alloy, echo, fable, onyx, nova, shimmer

# Kokoro (local)
KOKORO_MODEL_PATH=./models/kokoro       # [OPTIONAL] Path to Kokoro model files
KOKORO_VOICE=af                         # [OPTIONAL] Voice preset

# ----------------------------------------------------------------------------
# CODE EXECUTION (Full mode only)
# ----------------------------------------------------------------------------
# Judge0 — self-hosted code execution engine
JUDGE0_URL=http://localhost:2358        # [OPTIONAL] Judge0 API URL (only in full mode)
JUDGE0_API_KEY=                         # [OPTIONAL] Judge0 auth token (if configured)
JUDGE0_MAX_CPU_TIME=5                   # [OPTIONAL] Max CPU time per execution in seconds
JUDGE0_MAX_MEMORY_KB=128000             # [OPTIONAL] Max memory per execution in KB

# ----------------------------------------------------------------------------
# ENCRYPTION
# ----------------------------------------------------------------------------
# Used to encrypt BYOK API keys stored in the database
ENCRYPTION_KEY=                         # [REQUIRED] Generate with: openssl rand -hex 32

# ----------------------------------------------------------------------------
# SESSION CONFIGURATION
# ----------------------------------------------------------------------------
SESSION_MAX_DURATION_MINUTES=60         # [OPTIONAL] Max session length
SESSION_MAX_QUESTIONS=15                # [OPTIONAL] Max questions per session
ANSWER_MAX_DURATION_SECONDS=300         # [OPTIONAL] Max time per answer (5 min default)
SILENCE_THRESHOLD_MS=2000               # [OPTIONAL] Pause detection threshold in ms
FILLER_WORDS=um,uh,like,you know,basically,actually,literally,right,so yeah  # [OPTIONAL] Comma-separated filler word list

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000              # [OPTIONAL] Rate limit window (1 min)
RATE_LIMIT_MAX_REQUESTS=100             # [OPTIONAL] Max requests per window

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
LOG_LEVEL=info                          # [OPTIONAL] debug, info, warn, error
LOG_FORMAT=json                         # [OPTIONAL] json or pretty

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
NODE_ENV=production                     # [OPTIONAL] development, production, test
PORT=3000                               # [OPTIONAL] Server port
